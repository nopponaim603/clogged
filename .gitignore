# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
# Recommended: add any editor/OS/tool-specific ignore rules from the Global/ templates as needed.
# See: https://github.com/github/gitignore/tree/main/Global
#
# NOTE: The Unity project in this repo lives under `Unity-Projects/`, so the
# Unity-generated paths below are scoped to that folder (not the repo root).

# =====================
# Unity project (Unity-Projects/)
# =====================
Unity-Projects/.utmp/
Unity-Projects/[Ll]ibrary/
Unity-Projects/[Tt]emp/
Unity-Projects/[Oo]bj/
Unity-Projects/[Bb]uild/
Unity-Projects/[Bb]uilds/
Unity-Projects/[Ll]ogs/
Unity-Projects/[Uu]ser[Ss]ettings/
Unity-Projects/[Mm]emoryCaptures/
Unity-Projects/[Rr]ecordings/
Unity-Projects/ServerData
Unity-Projects/[Aa]ssets/Plugins/Editor/JetBrains*
# /[Aa]ssets/AssetStoreTools*  (uncomment to ignore the asset store tools plugin)
Unity-Projects/[Aa]ssets/StreamingAssets/aa*
Unity-Projects/[Aa]ssets/AddressableAssetsData/link.xml*
Unity-Projects/[Aa]ssets/Addressables_Temp*
Unity-Projects/[Aa]ssets/AddressableAssetsData/*/*.bin*
Unity-Projects/[Aa]ssets/Unity.VisualScripting.Generated/**
Unity-Projects/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
Unity-Projects/[Aa]ssets/[Ss]ceneDependencyCache*

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
*.blend1
*.blend1.meta

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono auto generated files
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# TestRunner generated files
InitTestScene*.unity*

# =====================
# Editor / IDE
# =====================
# Jetbrains Rider personal-layer settings
*.DotSettings.user

# Rider
/.idea/

# VS Code
.vscode/

# =====================
# OS generated files
# =====================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =====================
# AI Gateway local data
# =====================
# 9Router Data
ai-gateway/9router/data/

# OmniRoute Data
ai-gateway/omniroute/data/

# mcp-unity (cloned third-party Unity MCP bridge)
ai-gateway/mcp-unity/

# Node.js dependencies & logs
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
